	column Quarter
		lineageTag: e28501fb-2f72-4dba-bf29-e50a26b7effc
		summarizeBy: none
		isNameInferred
		sourceColumn: [Quarter]

		annotation SummarizationSetBy = Automatic

	partition Date = calculated
		mode: import
		source =
				
				VAR MinimumDate =
				    MINX(
				        FILTER(
				            bi_offer_features,
				            NOT ISBLANK(bi_offer_features[invoice_date])
				        ),
				        bi_offer_features[invoice_date]
				    )
				VAR MaximumDate =
				    MAXX(
				        FILTER(
				            bi_offer_features,
				            NOT ISBLANK(bi_offer_features[invoice_date])
				        ),
				        bi_offer_features[invoice_date]
				    )
				RETURN
				ADDCOLUMNS(
				    CALENDAR(MinimumDate, MaximumDate),
				    "Year", YEAR([Date]),
				    "Month Number", MONTH([Date]),
				    "Month", FORMAT([Date], "MMM"),
				    "Year Month", FORMAT([Date], "YYYY-MM"),
				    "Quarter", "Q" & FORMAT([Date], "Q")
				)

	annotation PBI_Id = cbd7832573594f5ba2964cd424a38452

